# Database
DATABASE_URL="file:./dev.db"

# LLM Configuration (REQUIRED for Vercel/Docker)
# Set these environment variables in Vercel dashboard
ZAI_BASE_URL="https://your-llm-api.com/v1"
ZAI_API_KEY="your-api-key"

# Alternative: Create ~/.z-ai-config file locally:
# {"baseUrl": "https://your-llm-api.com/v1", "apiKey": "your-api-key"}

# GitHub (optional - for prototype publishing)
# GITHUB_TOKEN="ghp_your_github_token"
# GITHUB_REPO="your-username/prototypes-repo"

# Web Search (optional - for competitor analysis)
# SEARCH_API_KEY="your-search-api-key"
