          supportScore: '⭐⭐⭐'
        }
      ],
      indirect: [
        {
          name: 'Excel / Google Sheets',
          description: 'Табличные процессоры для учёта',
          approach: 'Самостоятельное создание системы',
          overlap: 'Хранение данных, процессы',
