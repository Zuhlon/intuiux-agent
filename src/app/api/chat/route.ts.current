function getFallbackResponse(agentType: string, message: string): string {
  const idea = extractFormedIdea(message);
  const lowerMessage = message.toLowerCase();
  
  // === АНАЛИТИК ИДЕЙ ===
  if (agentType === 'transcription_analyst') {
    // Извлекаем исходный текст пользователя
    let sourceText = '';
    
    // Паттерн 1: После "Исходный текст:"
    const sourceMatch = message.match(/Исходный текст:\s*([\s\S]*)$/i);
    if (sourceMatch && sourceMatch[1]) {
      sourceText = sourceMatch[1].trim();
    }
    
    // Паттерн 2: Последний существенный абзац
    if (!sourceText || sourceText.length < 20) {
      const paragraphs = message.split(/\n\n+/).filter(p => p.trim().length > 20);
      if (paragraphs.length > 0) {
        // Берём последний абзац который выглядит как описание
        for (let i = paragraphs.length - 1; i >= 0; i--) {
          if (!paragraphs[i].includes('Проанализируй') && 
              !paragraphs[i].includes('Структура ответа') &&
              !paragraphs[i].startsWith('##')) {
            sourceText = paragraphs[i].trim();
            break;
          }
        }
      }
    }
    
    // Паттерн 3: Весь текст если ничего не найдено
    if (!sourceText || sourceText.length < 20) {
      sourceText = message.trim();
    }
    
    console.log(`[Fallback transcription_analyst] sourceText: "${sourceText.substring(0, 200)}..."`);
    
    // Анализируем исходный текст и генерируем конкретную идею
    const analysis = analyzeSourceIdea(sourceText);
    
    return `## 💡 Название идеи
**${analysis.name}**

### Описание сути
${analysis.description}

### Целевая аудитория
${analysis.targetAudience}

### Ключевая ценность (Value Proposition)
${analysis.valueProposition}

### Основные функции
${analysis.functions.map((f, i) => `${i + 1}. ${f}`).join('\n')}

### Уникальное преимущество
${analysis.uniqueAdvantage}

### Ключевые метрики успеха
${analysis.metrics.map((m, i) => `${i + 1}. ${m}`).join('\n')}

### Потенциальные риски
${analysis.risks.map((r, i) => `${i + 1}. ${r}`).join('\n')}`;
  }

// === ФУНКЦИЯ АНАЛИЗА ИДЕИ ===
function analyzeSourceIdea(sourceText: string): {
  name: string;
  description: string;
  targetAudience: string;
  valueProposition: string;
  functions: string[];
  uniqueAdvantage: string;
  metrics: string[];
  risks: string[];
} {
  const lowerText = sourceText.toLowerCase();
  
  // Определяем тип продукта по КОНТЕКСТУ запроса
  let productType = 'general';
  let productKeywords: string[] = [];
  
  // Онлайн-запись / Календарь записи (проверяем ПЕРВЫМ, так как это специфичная категория)
  if ((lowerText.includes('запис') && (lowerText.includes('календар') || lowerText.includes('расписан') || lowerText.includes('слот') || lowerText.includes('приём'))) ||
      lowerText.includes('онлайн запис') || lowerText.includes('запись к') || lowerText.includes('запись на приём') ||
      lowerText.includes('бронирование времени') || lowerText.includes('yclients') || lowerText.includes('dikidi') ||
      (lowerText.includes('логопед') || lowerText.includes('врач') || lowerText.includes('клиник') || 
       lowerText.includes('салон') || lowerText.includes('мастер') || lowerText.includes('психолог') ||
       lowerText.includes('репетитор') || lowerText.includes('учитель')) && lowerText.includes('запис')) {
    productType = 'booking';
    productKeywords = ['онлайн-запись', 'календарь', 'расписание', 'бронирование'];
  }
  // Такси / Транспорт
  else if (lowerText.includes('такси') || lowerText.includes('taxi') || 
      (lowerText.includes('заказ') && lowerText.includes('машин')) ||
      lowerText.includes('попутн') || lowerText.includes('каршеринг')) {
    productType = 'taxi';
    productKeywords = ['такси', 'заказ поездок', 'транспорт', 'логистика'];
  }
  // АТС / Телефония (только если явно про телефонные звонки)
  else if ((lowerText.includes('атс') || lowerText.includes('телефони')) && 
           (lowerText.includes('звонок') || lowerText.includes('ivr') || lowerText.includes('sip') || lowerText.includes('call'))) {
    productType = 'ats';
    productKeywords = ['телефония', 'звонки', 'АТС', 'коммуникации'];
  }
  // Дашборд / Аналитика (только если явно про аналитику данных)
  else if ((lowerText.includes('дашборд') || lowerText.includes('аналитик') || lowerText.includes('метрик') || 
            lowerText.includes('отчёт') || lowerText.includes('kpi') || lowerText.includes('bi')) &&
           (lowerText.includes('данн') || lowerText.includes('график') || lowerText.includes('визуализац') || lowerText.includes('виджет'))) {
    productType = 'dashboard';
    productKeywords = ['аналитика', 'визуализация', 'дашборд', 'данные'];
  }
  // CRM (только если явно про продажи и клиентов)
  else if (lowerText.includes('crm') || 
           (lowerText.includes('клиент') && lowerText.includes('продаж')) ||
           (lowerText.includes('сделк') && lowerText.includes('воронк'))) {
    productType = 'crm';
    productKeywords = ['клиенты', 'продажи', 'CRM', 'сделки'];
  }
  // E-commerce / Маркетплейс
  else if (lowerText.includes('маркетплейс') || lowerText.includes('торговая площадка') ||
           (lowerText.includes('магазин') && (lowerText.includes('товар') || lowerText.includes('заказ') || lowerText.includes('корзин'))) ||
           lowerText.includes('e-commerce') || lowerText.includes('ecommerce')) {
    productType = 'ecommerce';
    productKeywords = ['торговля', 'заказы', 'магазин', 'продажи'];
  }
  // Мессенджер
  else if (lowerText.includes('мессендж') || lowerText.includes('чат-приложение') ||
           (lowerText.includes('чат') && lowerText.includes('сообщен'))) {
    productType = 'messenger';
    productKeywords = ['общение', 'сообщения', 'чат', 'коммуникация'];
  }
  // Доставка / Логистика
  else if (lowerText.includes('доставк') && (lowerText.includes('груз') || lowerText.includes('посылк') || lowerText.includes('курьер')) ||
           lowerText.includes('логистик') || lowerText.includes('грузоперевозк')) {
    productType = 'logistics';
    productKeywords = ['доставка', 'логистика', 'грузоперевозки', 'трекинг'];
  }
  // EdTech / Образование
  else if ((lowerText.includes('образован') || lowerText.includes('обучен') || lowerText.includes('edtech')) &&
           (lowerText.includes('курс') || lowerText.includes('урок') || lowerText.includes('студент') || lowerText.includes('учитель'))) {
    productType = 'education';
    productKeywords = ['образование', 'обучение', 'курсы', 'знания'];
  }
  // Медицина / Здравоохранение
  else if ((lowerText.includes('медицин') || lowerText.includes('клиник') || lowerText.includes('больниц') ||
            lowerText.includes('врач') || lowerText.includes('пациент')) &&
           !lowerText.includes('запис')) {
    productType = 'healthcare';
    productKeywords = ['медицина', 'пациенты', 'врачи', 'здоровье'];
  }
  
  // Извлекаем название из текста
  let name = '';
  
  // Пытаемся найти явное название
  const namePatterns = [
    /(?:названи[еи]|продукт|проект|сервис|приложение|платформа)[^:]*:?\s*["«]?([А-Яа-яA-Za-z0-9\s]{2,50})["»]?/i,
    /^([А-Яа-яA-Za-z0-9\s]{5,50})(?:\s*[-–—]\s*это|\s*[-–—]\s*приложение|\s*[-–—]\s*платформа)/i,
  ];
  
  for (const pattern of namePatterns) {
    const match = sourceText.match(pattern);
    if (match && match[1]) {
      name = match[1].trim().replace(/^["«»]+|["«»]+$/g, '');
      if (name.length > 3) break;
    }
  }
  
  // Если название не найдено, генерируем на основе типа
  if (!name || name.length < 3) {
    const nameGenerators: Record<string, () => string> = {
      ats: () => {
        if (lowerText.includes('малый бизнес') || lowerText.includes('малого бизнеса')) return 'Виртуальная АТС для малого бизнеса';
        if (lowerText.includes('аналтик') || lowerText.includes('виджет')) return 'Аналитическая АТС-платформа';
        return 'Облачная Виртуальная АТС';
      },
      taxi: () => {
        if (lowerText.includes('бизнес') || lowerText.includes('корпоратив')) return 'Корпоративное такси-приложение';
        if (lowerText.includes('международн') || lowerText.includes('международ')) return 'Международное такси-приложение';
        return 'Такси-сервис';
      },
      dashboard: () => {
        if (lowerText.includes('виджет')) return 'Виджетный дашборд';
        if (lowerText.includes('real-time') || lowerText.includes('реальн')) return 'Real-time аналитика';
        return 'Бизнес-дашборд';
      },
      crm: () => {
        if (lowerText.includes('малый бизнес')) return 'CRM для малого бизнеса';
        return 'CRM-платформа';
      },
      ecommerce: () => 'E-commerce платформа',
      messenger: () => 'Корпоративный мессенджер',
      logistics: () => 'Платформа логистики',
      booking: () => {
        if (lowerText.includes('логопед') || lowerText.includes('медицин') || lowerText.includes('клиник')) return 'Сервис онлайн-записи для медицины';
        if (lowerText.includes('салон') || lowerText.includes('красот') || lowerText.includes('парикмахер')) return 'Сервис онлайн-записи для салонов';
        if (lowerText.includes('психолог') || lowerText.includes('консульт')) return 'Платформа записи к специалистам';
        return 'Сервис онлайн-записи';
      },
      general: () => {
        const words = sourceText.split(/\s+/).filter(w => w.length > 3);
        return words.slice(0, 3).join(' ') || 'Инновационный продукт';
      }
    };
    name = (nameGenerators[productType] || nameGenerators.general)();
  }
  
  // Генерируем описание на основе исходного текста
  let description = sourceText;
  
  // Убираем лишние слова и форматируем
  description = description
    .replace(/^(название|продукт|проект)[^:]*:?\s*/i, '')
    .replace(/(?:нужно|необходимо|требуется|хочу|сделать|создать|разработать)\s*/gi, '')
    .trim();
  
  // Ограничиваем длину и добавляем контекст
  if (description.length > 300) {
    description = description.substring(0, 300).replace(/\s+\S*$/, '...');
  }
  
  // Если описание слишком короткое, добавляем контекст на основе типа
  if (description.length < 50) {
    const contextAdditions: Record<string, string> = {
      ats: ' — облачное решение для бизнес-телефонии с расширенными возможностями.',
      dashboard: ' — платформа для визуализации и анализа бизнес-данных.',
      crm: ' — система для управления взаимоотношениями с клиентами и автоматизации продаж.',
      ecommerce: ' — платформа для электронной коммерции с широкими возможностями.',
      messenger: ' — современное решение для корпоративных коммуникаций.',
      general: ' — инновационное решение для цифровизации бизнес-процессов.'
    };
    description += contextAdditions[productType] || contextAdditions.general;
  }
  
  // Определяем целевую аудиторию
  let targetAudience = '';
  
  if (lowerText.includes('малый бизнес') || lowerText.includes('малого бизнеса') || lowerText.includes('смп')) {
    targetAudience = `Малый и средний бизнес (МСБ) — компании от 5 до 100 сотрудников, которые ищут доступное и простое решение для ${productKeywords.slice(0, 2).join(' и ')}. Владельцы бизнеса, руководители отделов, IT-специалисты в небольших компаниях.`;
  } else if (lowerText.includes('enterprise') || lowerText.includes('крупн') || lowerText.includes('корпорат')) {
    targetAudience = `Крупные предприятия и корпорации — компании с 500+ сотрудников, требующие масштабируемости и интеграций. C-level руководители, IT-директора, руководители департаментов.`;
  } else if (lowerText.includes('стартап') || lowerText.includes('startup')) {
    targetAudience = `Стартапы и малые команды — быстрорастущие компании, которым нужно гибкое решение с быстрым стартом. Основатели стартапов, product-менеджеры, разработчики.`;
  } else {
    targetAudience = `Компании и специалисты, работающие с ${productKeywords[0] || 'цифровыми решениями'}. Руководители бизнеса, менеджеры, IT-специалисты, которые хотят оптимизировать рабочие процессы и повысить эффективность.`;
  }
  
  // Генерируем ценностное предложение
  const valueProps: Record<string, string> = {
    ats: `Упрощение бизнес-коммуникаций: настройка за 15 минут, интеграция с CRM, аналитика звонков и экономия до 40% на телефонии.`,
    taxi: `Быстрый и удобный заказ поездки: машина за 3-5 минут, прозрачное ценообразование, отслеживание в реальном времени и безопасность платежей.`,
    dashboard: `Принятие решений на основе данных: все метрики на одном экране, автоматические отчёты, real-time аналитика без необходимости технических знаний.`,
    crm: `Рост продаж на 30%+ через систематизацию работы с клиентами: автоматизация рутины, сквозная аналитика, напоминания о сделках.`,
    ecommerce: `Увеличение конверсии и среднего чека: быстрые онлайн-платежи, персонализация, интеграция с доставкой и складом.`,
    messenger: `Эффективная командная работа: мгновенные сообщения, видеозвонки, интеграции с рабочими инструментами, безопасность данных.`,
    logistics: `Оптимизация логистики: сокращение издержек на 20%, ускорение доставки на 30%, полная прозрачность цепочки поставок.`,
    booking: `Сокращение пустых слотов на 50%: онлайн-запись 24/7, автоматические напоминания, интеграция с календарями и мессенджерами.`,
    general: `Экономия времени и ресурсов за счёт автоматизации ключевых процессов, интуитивный интерфейс и быстрая окупаемость.`
  };
  const valueProposition = valueProps[productType] || valueProps.general;
  
  // Генерируем функции на основе типа и исходного текста
  const functionSets: Record<string, string[]> = {
    ats: [
      'Виртуальная АТС с многоканальным номером и IVR-меню',
      'Запись и транскрибация звонков с AI-анализом',
      'Интеграция с CRM (Битрикс24, AmoCRM, 1С)',
      'Аналитика звонков: отчёты по операторам, пикам нагрузки, конверсии',
      'Мобильное приложение для приёма звонков из любого места',
      'Омниканальность: телефония + чаты + email в одном окне'
    ],
    taxi: [
      'Карта с отображением ближайших машин в реальном времени',
      'Поиск и выбор маршрута с учётом трафика и цены',
      'Система оплаты: карты, Apple Pay, Google Pay, наличные',
      'Отслеживание поездки в реальном времени с ETA',
      'Рейтинг водителей и отзывы пассажиров',
      'Предварительный заказ и планирование поездок'
    ],
    booking: [
      'Календарь с визуализацией свободных слотов для записи',
      'Онлайн-запись через сайт, виджет или мессенджеры',
      'Автоматические SMS/Email напоминания о приёме',
      'Ведение карточек пациентов/клиентов с историей визитов',
      'Интеграция с Google Calendar, Яндекс.Календарь, Outlook',
      'Приём онлайн-оплат и предоплат за услуги'
    ],
    dashboard: [
      'Конструктор дашбордов с drag-and-drop виджетами',
      'Real-time обновление данных с настраиваемой частотой',
      'Интеграция с множеством источников данных',
      'Автоматические отчёты и алерты по email/мессенджеры',
      'Совместная работа и расшаривание дашбордов',
      'Мобильная версия для мониторинга в пути'
    ],
    crm: [
      'Управление воронкой продаж с визуализацией этапов',
      'Контакт-профили с историей взаимодействий',
      'Автоматизация задач и напоминаний',
      'Email и WhatsApp интеграции для outreach',
      'Аналитика продаж и прогнозирование',
      'Мобильное приложение для продажников в полях'
    ],
    ecommerce: [
      'Каталог товаров с фильтрами и поиском',
      'Корзина и checkout с множеством платёжных методов',
      'Интеграция с доставочными сервисами',
      'Система скидок, промокодов и лояльности',
      'SEO-оптимизация и маркетинговые инструменты',
      'Аналитика продаж и поведения пользователей'
    ],
    messenger: [
      'Личные и групповые чаты с историей',
      'Видеозвонки и демонстрация экрана',
      'Файловое хранилище и поиск по сообщениям',
      'Тематические каналы и потоки',
      'Интеграция с внешними сервисами через API',
      'Шифрование и контроль доступа'
    ],
    logistics: [
      'Отслеживание грузов в реальном времени',
      'Оптимизация маршрутов доставки',
      'Управление складскими запасами',
      'Интеграция с транспортными компаниями',
      'Автоматическое формирование накладных и документов',
      'Аналитика логистики и прогнозирование'
    ],
    general: [
      'Управление основными сущностями и процессами',
      'Аналитика и отчётность в реальном времени',
      'Интеграция с популярными сервисами',
      'Настраиваемые уведомления и алерты',
      'Мобильное приложение для работы в пути',
      'Ролевая модель доступа и безопасность'
    ]
  };
  
  // Выбираем функции, упоминаемые в тексте, или используем стандартные
  let functions = functionSets[productType] || functionSets.general;
  
  // Если в тексте есть специфичные упоминания, адаптируем функции
  if (lowerText.includes('виджет')) {
    functions = functions.map(f => f.includes('Конструктор') || f.includes('дашборд') ? f : f);
  }
  
  // Берём 5-6 функций
  functions = functions.slice(0, 6);
  
  // Генерируем уникальное преимущество
  const advantages: Record<string, string> = {
    ats: 'Российская разработка с глубокой интеграцией в локальный рынок: работа с российскими операторами, соответствие 152-ФЗ, техподдержка на русском языке в часовом поясе клиента. Простота настройки — старт за 15 минут без IT-специалиста.',
    taxi: 'Локальный агрегатор с фокусом на российском рынке: работа с лицензированными таксопарками, интеграция с Яндекс.Картами, прозрачное ценообразование без скрытых комиссий. Безопасность пассажиров — верификация водителей.',
    dashboard: 'Бесплатный старт без ограничений по функционалу. Готовые шаблоны дашбордов для типовых задач. No-code подход — аналитика доступна бизнес-пользователям, а не только техническим специалистам.',
    crm: 'Лучшее соотношение цена/функционал на рынке. Не перегружен лишним функционалом — фокус на продажах. Быстрое внедрение за 1 день вместо месяцев.',
    ecommerce: 'Готовая интеграция с российскими платёжными системами и доставкой. Адаптация под требования 54-ФЗ. Локальная техподдержка.',
    messenger: 'Полный контроль над данными — возможность on-premise установки. Интеграция с корпоративными системами. Гибкая настройка прав и политик.',
    logistics: 'Глубокая интеграция с российскими транспортными компаниями. Работа с ЕГАИС и Меркурий. Соответствие требованиям документооборота.',
    booking: 'Специализация на конкретной нише (логопеды, психологи, медицинские специалисты). Упрощённый интерфейс без перегруженности. Быстрый старт за 5 минут. Интеграция с российскими мессенджерами.',
    general: 'Специализация на российском рынке с учётом локальных особенностей. Прозрачное ценообразование без скрытых платежей. Быстрая техподдержка на русском языке.'
  };
  const uniqueAdvantage = advantages[productType] || advantages.general;
  
  // Метрики успеха
  const metricsSets: Record<string, string[]> = {
    ats: [
      'Среднее время обработки звонка — цель: снижение на 20%',
